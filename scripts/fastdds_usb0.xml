<?xml version="1.0" encoding="UTF-8"?>
<!-- Restrict Fast DDS to the Create 3 USB-ethernet link (usb0, 192.168.186.3) so
     multi-interface hosts discover the base's SPDP multicast on the right NIC.
     Use with:  export FASTRTPS_DEFAULT_PROFILES_FILE=.../scripts/fastdds_usb0.xml -->
<profiles xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
  <transport_descriptors>
    <transport_descriptor>
      <transport_id>usb0_udp</transport_id>
      <type>UDPv4</type>
      <interfaceWhiteList>
        <address>127.0.0.1</address>
        <address>192.168.186.3</address>
      </interfaceWhiteList>
    </transport_descriptor>
  </transport_descriptors>

  <participant profile_name="usb0_default" is_default_profile="true">
    <rtps>
      <userTransports>
        <transport_id>usb0_udp</transport_id>
      </userTransports>
      <useBuiltinTransports>false</useBuiltinTransports>
    </rtps>
  </participant>
</profiles>
